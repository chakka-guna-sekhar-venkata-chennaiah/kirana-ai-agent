# ── LLM ──────────────────────────────────────────────────────────────────────
# Get your key from https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ── Neo4j Aura (Graph Database) ───────────────────────────────────────────────
# Create a free instance at https://console.neo4j.io
# After creating, download the credentials file — values are all listed there
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-aura-password-here
NEO4J_DATABASE=neo4j
AURA_INSTANCEID=xxxxxxxx
AURA_INSTANCENAME=kirana

# ── SQLite ────────────────────────────────────────────────────────────────────
# Path where the local SQLite DB will be created (leave as default)
SQLITE_DB_PATH=kirana_store.db
